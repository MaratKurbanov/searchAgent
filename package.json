{
  "name": "cloudflare-ai-search",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/generate-manifest.js && vite",
    "build": "node scripts/generate-manifest.js && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "worker:dev": "concurrently \"vite build --watch\" \"wrangler dev --env hadis --local\"",
    "worker:dev:keller": "concurrently \"vite build --watch\" \"wrangler dev --env keller --local\"",
    "worker:build": "vite build && wrangler deploy --dry-run --env hadis",
    "worker:deploy": "npm run build && wrangler deploy --env hadis && wrangler deploy --env keller",
    "worker:deploy:hadis": "wrangler deploy --env hadis",
    "worker:deploy:keller": "wrangler deploy --env keller",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@cloudflare/ai-search-snippet": "^0.0.30",
    "@vitejs/plugin-react": "^4.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "vite": "^5.4.21"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "concurrently": "^9.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "patch-package": "^8.0.1",
    "playwright": "^1.59.1",
    "wrangler": "^4.81.1"
  }
}
